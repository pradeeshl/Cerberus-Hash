# Cerberus-Hash Environment Configuration Template
# Copy this file to '.env' and modify the values as needed for your deployment environment.

# JWT and Authentication Settings
SECRET_KEY=cerberus-hash-dev-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database URL (SQLite default path)
# DATABASE_URL=sqlite:///backend/cerberus_hash.db

# Directory where uploaded PCAP files are temporarily saved
# UPLOAD_DIR=uploads

# Path to the compiled or raw YARA rules file
# YARA_RULES_PATH=yara_rules/malware_rules.yar
